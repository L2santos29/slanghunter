# ──────────────────────────────────────────────
# SlangHunter – .gitignore
# ──────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# IDE / Editor settings
.vscode/
.idea/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini

# Test / Coverage reports
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Environment variables
.env
.env.local
