# ──────────────────────────────────────────────
# SlangHunter – .gitignore
# ──────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# IDE / Editor settings
.vscode/
.idea/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
Desktop.ini

# Test / Coverage reports
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.mypy_cache/
.tox/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Environment variables — never commit real secrets
.env
*.env
.env.*
.env*
!.env.example
secrets/
*.pem
*.key

# Build artifacts (already listed above, kept for explicitness)
dist/
*.egg-info/
build/

# Docker — local dev overrides contain insecure placeholder secrets
docker-compose.override.yml

# Lock files (requirements-*.lock) are intentionally committed — NOT ignored here.
# Do NOT add requirements-*.lock to this file.
