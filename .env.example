# SlangHunter API — Environment Configuration Template
# Copy this file to .env and fill in values before deploying.
# .env is gitignored; .env.example is committed.

# REQUIRED for production: API key for the /reload endpoint.
# If unset, /reload is unauthenticated (development only).
SLANGHUNTER_RELOAD_KEY=your-secret-key-here

# Comma-separated list of allowed CORS origins.
# Leave empty to block all cross-origin requests (recommended for internal APIs).
SLANGHUNTER_CORS_ORIGINS=

# Rate limiting (requests per window per client IP)
SLANGHUNTER_RATE_LIMIT_MAX_REQUESTS=60
SLANGHUNTER_RATE_LIMIT_WINDOW_SECONDS=60

# Set to "true" only when running behind a trusted reverse proxy (nginx, Caddy, etc.)
# NEVER set to "true" for direct internet-facing deployments.
SLANGHUNTER_TRUST_PROXY_HEADERS=false
